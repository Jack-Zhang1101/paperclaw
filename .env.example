# SerpAPI Key（可选，用于 Google Scholar 搜索）
# 注册地址：https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Semantic Scholar API Key（可选，提高速率限制）
# 申请地址：https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# 邮件配置（用于每周报告发送）
# Gmail 应用专用密码获取：https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=recipient@example.com

# 工作目录（可选，默认 ~/.paperclaw/workspace）
# PAPERCLAW_WORKSPACE=/path/to/your/workspace

# Obsidian vault 路径（用于自动同步日报和周报）
# 日报保存至: $OBSIDIAN_VAULT/PaperClaw/daily/YYYY-MM-DD.md
# 周报保存至: $OBSIDIAN_VAULT/PaperClaw/weekly/YYYY-MM-DD_weekly_report.md
OBSIDIAN_VAULT=/path/to/your/obsidian/vault
